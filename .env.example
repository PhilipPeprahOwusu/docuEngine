# Project Information
PROJECT_NAME=Document Intelligence Platform
VERSION=2.0.0
DESCRIPTION=Enterprise-grade policy-governed document management with AI agents
API_V1_STR=/api/v1

# Security
SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Comma separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Database (PostgreSQL required)
DATABASE_URL=postgresql://user:password@localhost:5432/document_intelligence

# LLM Configuration
# Step 1: Select your LLM provider (openai, gemini, or anthropic)
LLM_PROVIDER=openai

# Step 2: Provide API key for your selected provider
# For OpenAI (ChatGPT)
OPENAI_API_KEY=sk-...

# For Google Gemini
# GEMINI_API_KEY=...

# For Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# LLM Parameters (optional - uses provider defaults if not set)
DEFAULT_MODEL=
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2000

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
S3_BUCKET=document-intelligence-docs

# Redis
REDIS_URL=redis://localhost:6379

# Notifications
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Application
DEBUG=True
ENVIRONMENT=development
